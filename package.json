{
  "name": "duck-tail",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "npm run sprites && astro dev",
    "build": "npm run sprites && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint . && stylelint \"**/*.{css,astro}\"",
    "lint:fix": "eslint . --fix && stylelint \"**/*.{css,astro}\" --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "check": "npm run lint && npm run format:check && astro check && npm run build",
    "check:quick": "npm run lint && npm run format:check && astro check",
    "sprites": "tsx scripts/aseprite-to-css.ts"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.7.3",
    "astro": "^7.0.4",
    "astro-favicons": "^3.1.6",
    "sharp": "^0.35.0",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "astro-eslint-parser": "^2.1.0",
    "eslint": "^10.6.0",
    "eslint-plugin-astro": "^2.1.1",
    "postcss": "^8.5.16",
    "postcss-html": "^1.8.1",
    "prettier": "^3.9.4",
    "prettier-plugin-astro": "^0.14.1",
    "stylelint": "^17.14.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard": "^40.0.0",
    "tsx": "^4.23.0",
    "typescript-eslint": "^8.63.0"
  }
}
