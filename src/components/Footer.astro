---
import type { BreadcrumbTrail } from "@/types/breadcrumb.ts";

import "@/styles/footer.css";

export interface Props {
  prevUrl: string;
  nextUrl?: string;
  breadcrumb?: BreadcrumbTrail;
}

const { prevUrl, nextUrl, breadcrumb } = Astro.props;
---

<footer>
  <button id="prev" class="footer-button" data-url={prevUrl}
    >&lt;&lt; 戻る</button
  >
  <button id="open-menu" class="footer-button" aria-label="メニューを開く">
    <span data-sprite="menu"></span>
    メニュー
  </button>
  <button id="close-menu" class="footer-button" aria-label="メニューを閉じる">
    × 閉じる
  </button>
  <button id="next" class="footer-button" data-url={nextUrl} disabled={!nextUrl}
    >&gt;&gt; 進む</button
  >
</footer>

<div id="menu-popup">
  {
    breadcrumb && (
      <ul class="breadcrumb">
        {breadcrumb?.map((item) => (
          <li class="breadcrumb-item">
            {item.url ? (
              <a class="breadcrumb-data" href={item.url}>
                <span data-sprite={item.symbol} />
                <span class="breadcrumb-label">{item.name}</span>
              </a>
            ) : (
              <span class="breadcrumb-data">
                <span data-sprite={item.symbol} />
                <span class="breadcrumb-label">{item.name}</span>
              </span>
            )}
          </li>
        ))}
      </ul>
    )
  }
  <ul id="menu-list"></ul>
</div>

<script>
  const main = document.querySelector("main") as HTMLElement;

  // サブタイトルを取得してメニューに表示
  function getHeadings() {
    const headings = main.querySelectorAll(
      "h1, h2",
    ) as NodeListOf<HTMLHeadingElement>;
    const menuList = document.getElementById("menu-list") as HTMLUListElement;
    if (headings.length > 0) {
      // サブタイトルがある場合はメニューに追加
      headings.forEach((subtitle, index) => {
        const li = document.createElement("li");
        // サブタイトルにidを付与
        subtitle.id = `${index}`;
        const a = document.createElement("a");
        a.href = `#${subtitle.id}`;
        a.textContent = subtitle.textContent;
        a.addEventListener("click", () => scrollToHash(subtitle.id));
        li.appendChild(a);
        menuList.appendChild(li);
      });
    }
  }
  window.addEventListener("DOMContentLoaded", getHeadings);

  // 履歴を残さずにページ内リンクで移動する
  function scrollToHash(id: string) {
    const target = document.getElementById(id);
    if (target) {
      // 履歴を残さずにURLのハッシュを変更
      history.replaceState(null, "", `#${id}`);
      // スムーズスクロールで移動
      target.scrollIntoView({ behavior: "smooth" });
    }
  }

  const openMenuButton = document.getElementById(
    "open-menu",
  ) as HTMLButtonElement;
  const closeMenuButton = document.getElementById(
    "close-menu",
  ) as HTMLButtonElement;
  const menuPopup = document.getElementById("menu-popup") as HTMLDivElement;

  // メニューを開く
  function openMenu() {
    menuPopup.style.display = "flex";
    openMenuButton.style.display = "none";
    closeMenuButton.style.display = "flex";
    // メニュー外をクリックしたら閉じるイベントを追加
    document.addEventListener("click", clickOutsideMenu);
  }
  openMenuButton.addEventListener("click", openMenu);

  // メニューを閉じる
  function closeMenu() {
    menuPopup.style.display = "none";
    openMenuButton.style.display = "flex";
    closeMenuButton.style.display = "none";
    // メニュー外をクリックしたら閉じるイベントを削除
    document.removeEventListener("click", clickOutsideMenu);
  }
  closeMenuButton.addEventListener("click", closeMenu);

  // メニュー外をクリックしたら閉じる
  function clickOutsideMenu(event: MouseEvent) {
    if (
      !menuPopup.contains(event.target as Node) &&
      !openMenuButton.contains(event.target as Node)
    ) {
      closeMenu();
    }
  }

  // 同一オリジンのURLのみ許可
  function getSafeNavigationUrl(raw: string | undefined): string | null {
    if (!raw) return null;

    try {
      // 相対URLも絶対URLも解決できる
      const url = new URL(raw, window.location.href);

      // http/https 以外は拒否
      if (url.protocol !== "http:" && url.protocol !== "https:") return null;

      // 同一オリジンは相対化して返す
      if (url.origin === window.location.origin) {
        return `${url.pathname}${url.search}${url.hash}`;
      }

      // pineduck.jp とそのサブドメインを許可
      if (
        url.hostname === "pineduck.jp" ||
        url.hostname.endsWith(".pineduck.jp")
      ) {
        // 許可済みの別サブドメインは絶対URLのまま返す
        return url.toString();
      }

      return null;
    } catch {
      return null;
    }
  }

  // 戻るボタンのクリックイベント
  // クエリパラメーターでURLが指定されていなければdata-url属性に指定されたURLに遷移する、指定されていれば指定URLに遷移する
  const prevButton = document.getElementById("prev") as HTMLButtonElement;
  function goPrev() {
    const urlParams = new URLSearchParams(window.location.search);
    const prevUrl = urlParams.get("prev") || prevButton.dataset.url;
    const safePrevUrl = getSafeNavigationUrl(prevUrl);
    if (safePrevUrl) {
      window.location.href = safePrevUrl;
    }
  }
  prevButton.addEventListener("click", goPrev);

  // 進むボタンのクリックイベント
  const nextButton = document.getElementById("next") as HTMLButtonElement;
  function goNext() {
    const urlParams = new URLSearchParams(window.location.search);
    const nextUrl = urlParams.get("next") || nextButton.dataset.url;
    const safeNextUrl = getSafeNavigationUrl(nextUrl);
    if (safeNextUrl) {
      window.location.href = safeNextUrl;
    }
  }
  nextButton.addEventListener("click", goNext);
</script>
