---
import { render } from "astro:content";
import type { GetStaticPaths, InferGetStaticPropsType } from "astro";

import {
  getAllArticles,
  getAllCategories,
  checkUniqueTailSlugs,
  checkSlugCategoryConflicts,
} from "@/lib/tail.ts";

import Layout from "@/layouts/ArticleLayout.astro";

import { SITE_TITLE, PINEDUCK_URL, LP_URL } from "@/consts.ts";

export const getStaticPaths = (async () => {
  const allArticles = await getAllArticles();
  const allCategories = await getAllCategories(allArticles);

  checkUniqueTailSlugs(allArticles);
  checkSlugCategoryConflicts(allArticles, allCategories);

  return allArticles.map((article) => {
    const category = allCategories.find(
      (category) => category.id === article.data.category.id,
    );

    if (!category) {
      throw new Error(
        `記事に対応するカテゴリが見つかりません。",: ${article.data.slug} (category: ${article.data.category.id})`,
      );
    }

    return {
      params: { slug: article.data.slug },
      props: { article, category },
    };
  });
}) satisfies GetStaticPaths;

type Props = InferGetStaticPropsType<typeof getStaticPaths>;
const { article, category }: Props = Astro.props;

const { Content } = await render(article);

const pageTitle = article.data.title + " | " + SITE_TITLE;
const pageDescription = article.data.description;
const prevUrl = "/" + article.data.category.id + "/";
---

<Layout
  title={pageTitle}
  description={pageDescription}
  index={true}
  prevUrl={prevUrl}
  breadcrumb={[
    { name: "PineDuck", symbol: "pineduck", url: PINEDUCK_URL },
    {
      name: "アヒルのしっぽ",
      symbol: "duck-tail",
      url: LP_URL,
    },
    {
      name: "すべての記事",
      symbol: "all",
      url: "/",
    },
    {
      name: category.data.name + "の記事",
      symbol: "category",
      url: prevUrl,
    },
    { name: article.data.title, symbol: "article" },
  ]}
>
  <article>
    <h1>{article.data.title}</h1>
    <p>{article.data.pubDate.toLocaleDateString("ja-JP")}</p>
    <Content />
  </article>
</Layout>
